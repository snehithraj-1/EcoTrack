PORT=5000
FLASK_DEBUG=1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://.*\.app\.github\.dev

GROQ_API_KEY=
CARBON_INTERFACE_API_KEY=

# Local development can use a JSON file that is ignored by git.
FIREBASE_SERVICE_ACCOUNT=serviceAccountKey.json

# GitHub Codespaces/deployments should use this instead of uploading a JSON file.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Web API key used by backend auth register/login helpers.
FIREBASE_WEB_API_KEY=
